# Android .dockerignore
# 排除不需要复制到 Docker 镜像中的文件

# Gradle 构建输出
.gradle/
build/
app/build/
*/build/

# IDE 配置文件
.idea/
*.iml
*.ipr
*.iws
.DS_Store

# 本地配置文件
local.properties
*.local

# 敏感信息文件
*.jks
*.keystore
secrets.properties
api_keys.properties

# Git 相关
.git/
.gitignore
.gitattributes

# CI/CD 配置
.github/
.travis.yml
.circleci/
 Jenkinsfile

# 文档
*.md
docs/

# 测试覆盖率报告
coverage/
*.exec

# 临时文件
*.log
*.tmp
*.temp
*.swp
*.swo
*~

# 原生构建输出
.externalNativeBuild/
.cxx/
captures/

# 安全扫描配置
.gitleaks.toml
.semgrep.yml
.trivyignore

# 其他
*.apk
*.aab
*.jar
*.war
