<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.IStudySpot" parent="Theme.MaterialComponents.Light.NoActionBar">

        <!-- ✅ 现代配色（低饱和 + 柔和） -->
        <item name="colorPrimary">@color/md_theme_primary</item>
        <item name="colorPrimaryVariant">@color/md_theme_primaryContainer</item>
        <item name="colorSecondary">@color/md_theme_secondary</item>
        <item name="colorSecondaryVariant">@color/md_theme_secondaryContainer</item>

        <!-- ❗ 不再强调 colorAccent（逐步弱化） -->
        <item name="colorAccent">@color/md_theme_secondary</item>

        <!-- ✅ 背景更干净 -->
        <item name="android:colorBackground">@color/md_theme_background</item>
        <item name="colorSurface">@color/md_theme_surface</item>

        <!-- ✅ 文本颜色 -->
        <item name="android:textColorPrimary">@color/md_theme_onSurface</item>
        <item name="android:textColorSecondary">@color/md_theme_onSurfaceVariant</item>

        <!-- ✅ 边框颜色 -->
        <item name="colorControlNormal">@color/md_theme_outline</item>

        <!-- ✅ 状态栏沉浸式 -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- 深色图标（现代系统默认） -->
        <item name="android:windowLightStatusBar">true</item>

        <!-- ✅ Ripple 更柔和 -->
        <item name="colorControlHighlight">@color/md_theme_ripple</item>

        <!-- ✅ 去掉强阴影（更扁平） -->
        <item name="elevationOverlayEnabled">false</item>

        <!-- ✅ 圆角体系（非常关键） -->
        <item name="shapeAppearanceSmallComponent">@style/Shape.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/Shape.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/Shape.Large</item>

    </style>


    <!-- 🌟 现代圆角（比默认更大） -->
    <style name="Shape.Small" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">12dp</item>
    </style>

    <style name="Shape.Medium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="Shape.Large" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerSize">20dp</item>
    </style>

    <!-- 🌟 卡片样式 -->
    <style name="CardView.Style" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/md_theme_surface</item>
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- 🌟 按钮样式 -->
    <style name="Button.Style" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingLeft">24dp</item>
        <item name="android:paddingRight">24dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- 🌟 文本输入样式 -->
    <style name="TextField.Style" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

</resources>