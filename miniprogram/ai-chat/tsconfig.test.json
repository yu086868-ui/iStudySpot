{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["jest", "node"],
    "typeRoots": ["./typings", "./node_modules/@types"],
    "module": "CommonJS",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "isolatedModules": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "miniprogram/**/*.ts",
    "miniprogram/__tests__/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
