page {
  height: 100%;
  background-color: #f0f7f0;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Inter', 'Segoe UI', Roboto, sans-serif;
}

.scrollarea {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  right: 0;
  box-sizing: border-box;
  padding-top: calc(44px + env(safe-area-inset-top));
}

.container {
  box-sizing: border-box;
  width: 100%;
  padding: 24rpx 32rpx;
  padding-bottom: 48rpx;
  overflow: hidden;
}

.header {
  padding: 40rpx 16rpx 32rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #2e7d32;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
  font-family: 'PingFang SC', 'Inter', sans-serif;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
  font-family: 'PingFang SC', 'Inter', sans-serif;
}

.loading-container,
.empty-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading-text,
.empty-text {
  font-size: 28rpx;
  color: #999;
  font-family: 'PingFang SC', 'Inter', sans-serif;
}

.character-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.character-card {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  box-sizing: border-box;
  width: 100%;
  padding: 28rpx;
  background-color: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.1);
  overflow: hidden;
}

.character-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #81c784 0%, #4caf50 100%);
  flex-shrink: 0;
  overflow: hidden;
  border: 4rpx solid #e8f5e9;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.character-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.character-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  font-family: 'PingFang SC', 'Inter', sans-serif;
  word-break: break-all;
}

.character-persona {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  word-break: break-all;
  overflow: hidden;
  font-family: 'PingFang SC', 'Inter', sans-serif;
}

.character-style {
  font-size: 26rpx;
  color: #81c784;
  line-height: 1.6;
  word-break: break-all;
  overflow: hidden;
  font-family: 'PingFang SC', 'Inter', sans-serif;
}

.arrow-icon {
  width: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
  align-self: center;
}

.arrow-icon text {
  font-size: 48rpx;
  color: #a5d6a7;
  font-weight: 300;
}
