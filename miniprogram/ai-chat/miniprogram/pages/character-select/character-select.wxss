page {
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #f0f7f0;
}

.scrollarea {
  flex: 1;
  overflow: hidden;
}

.container {
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.header {
  padding: 48rpx 16rpx 32rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #2e7d32;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.loading-container,
.empty-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading-text,
.empty-text {
  font-size: 28rpx;
  color: #999;
}

.character-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.character-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background-color: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.1);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.character-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.15);
}

.character-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #81c784 0%, #4caf50 100%);
  flex-shrink: 0;
  border: 4rpx solid #e8f5e9;
}

.character-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  overflow: hidden;
}

.character-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.character-persona {
  font-size: 26rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.character-style {
  font-size: 24rpx;
  color: #81c784;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arrow-icon {
  font-size: 48rpx;
  color: #a5d6a7;
  margin-left: 16rpx;
  font-weight: 300;
}
