page {
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.chat-container {
  display: flex;
  flex-direction: column;
  flex: 1;
  overflow: hidden;
}

.message-list {
  flex: 1;
  overflow: hidden;
}

.messages-wrapper {
  padding-bottom: 24rpx;
}

.bottom-anchor {
  height: 1rpx;
}

.nav-right {
  display: flex;
  align-items: center;
  padding-right: 16rpx;
}

.clear-btn {
  padding: 8rpx 20rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
}

.clear-btn text {
  font-size: 26rpx;
  color: #666;
}
