page {
  height: 100%;
  display: flex;
  flex-direction: column;
  background-color: #f0f7f0;
}

.chat-container {
  display: flex;
  flex-direction: column;
  flex: 1;
  overflow: hidden;
}

.message-list {
  flex: 1;
  overflow: hidden;
}

.messages-wrapper {
  padding: 16rpx 0;
  padding-bottom: 32rpx;
}

.bottom-anchor {
  height: 1rpx;
}

.nav-right {
  display: flex;
  align-items: center;
  padding-right: 16rpx;
}

.clear-btn {
  padding: 10rpx 24rpx;
  background-color: rgba(76, 175, 80, 0.1);
  border-radius: 32rpx;
}

.clear-btn text {
  font-size: 26rpx;
  color: #4caf50;
}
