page {
  height: 100%;
  background-color: #f0f7f0;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Inter', 'Segoe UI', Roboto, sans-serif;
}

.chat-container {
  position: absolute;
  top: calc(44px + env(safe-area-inset-top));
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  background-color: #f0f7f0;
}

.message-list {
  flex: 1;
  overflow: hidden;
}

.messages-wrapper {
  padding: 16rpx 24rpx;
  padding-bottom: 32rpx;
}

.bottom-anchor {
  height: 1rpx;
}

.nav-right {
  display: flex;
  align-items: center;
  padding-right: 16rpx;
}

.clear-btn {
  padding: 10rpx 24rpx;
  background-color: rgba(76, 175, 80, 0.1);
  border-radius: 32rpx;
}

.clear-btn text {
  font-size: 26rpx;
  color: #4caf50;
  font-family: 'PingFang SC', 'Inter', sans-serif;
}
