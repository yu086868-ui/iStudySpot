.input-container {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 1rpx solid #e8f5e9;
  gap: 16rpx;
}

.input-container.focus {
  border-top-color: #4caf50;
}

.input-wrapper {
  flex: 1;
  background-color: #f0f7f0;
  border-radius: 44rpx;
  padding: 18rpx 28rpx;
}

.message-input {
  font-size: 30rpx;
  width: 100%;
  color: #333;
}

.input-placeholder {
  color: #a5d6a7;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  padding: 0;
  border-radius: 36rpx;
  font-size: 26rpx;
  background-color: #e8f5e9;
  color: #81c784;
  border: none;
  font-weight: 500;
}

.send-btn.active {
  background: linear-gradient(135deg, #66bb6a 0%, #4caf50 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.send-btn[disabled] {
  background-color: #e8f5e9;
  color: #a5d6a7;
}
