.input-container {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 1rpx solid #e8f5e9;
}

.input-container.focus {
  border-top-color: #4caf50;
}

.input-wrapper {
  flex: 1;
  background-color: #f0f7f0;
  border-radius: 44rpx;
  padding: 18rpx 28rpx;
  min-width: 0;
}

.message-input {
  font-size: 30rpx;
  width: 100%;
  color: #333;
  font-family: 'PingFang SC', 'Inter', sans-serif;
}

.input-placeholder {
  color: #a5d6a7;
  font-family: 'PingFang SC', 'Inter', sans-serif;
}

.send-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 72rpx;
  padding: 0;
  margin-left: 16rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  background-color: #e8f5e9;
  color: #81c784;
  line-height: 72rpx;
  font-weight: 500;
  box-sizing: border-box;
  flex-shrink: 0;
  font-family: 'PingFang SC', 'Inter', sans-serif;
}

.send-btn.active {
  background: linear-gradient(135deg, #66bb6a 0%, #4caf50 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.send-btn.disabled {
  opacity: 0.5;
}
