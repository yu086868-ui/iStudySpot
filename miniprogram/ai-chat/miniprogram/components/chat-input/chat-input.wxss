.input-container {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #fff;
  border-top: 1rpx solid #e5e5e5;
  gap: 16rpx;
}

.input-container.focus {
  border-top-color: #07c160;
}

.input-wrapper {
  flex: 1;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.message-input {
  font-size: 28rpx;
  width: 100%;
}

.input-placeholder {
  color: #999;
}

.send-btn {
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background-color: #e5e5e5;
  color: #999;
  border: none;
  line-height: 1.4;
}

.send-btn.active {
  background-color: #07c160;
  color: #fff;
}

.send-btn[disabled] {
  background-color: #e5e5e5;
  color: #999;
}
