page {
  height: 100vh;
  background: #F5F5F5;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  padding: 32rpx;
  padding-bottom: 120rpx;
}

.header {
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #000000;
}

.stats-bar {
  margin-top: 16rpx;
}

.stats-text {
  font-size: 26rpx;
  color: #666666;
}

.datetime-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.picker-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.picker-row:last-child {
  border-bottom: none;
}

.picker-label {
  font-size: 28rpx;
  color: #333333;
  width: 160rpx;
}

.picker-value {
  font-size: 28rpx;
  color: #5CB885;
  padding: 8rpx 24rpx;
  background: #F0F9F4;
  border-radius: 8rpx;
}

.picker-separator {
  font-size: 28rpx;
  color: #333333;
  margin: 0 8rpx;
}

.time-display {
  background: #FFFFFF;
  border: 2rpx solid #5CB885;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.time-text {
  font-size: 28rpx;
  color: #333333;
  text-align: center;
  display: block;
}

.seat-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.seat-map {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 32rpx;
  padding: 24rpx;
  background: #FAFFF8;
  border-radius: 12rpx;
}

.seat-group {
  display: flex;
  flex-direction: column;
}

.group-header {
  display: flex;
  flex-direction: row;
  margin-bottom: 12rpx;
  padding-left: 48rpx;
}

.col-label {
  width: 64rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}

.seat-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 8rpx;
}

.row-label {
  width: 40rpx;
  font-size: 24rpx;
  color: #999999;
  text-align: center;
  margin-right: 8rpx;
}

.seat {
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 4rpx;
}

.seat-available {
  background: #C8E6C9;
}

.seat-occupied {
  background: #E0E0E0;
}

.seat-reserved {
  background: #FFF9C4;
}

.seat-maintenance {
  background: #FFCDD2;
}

.seat-selected {
  background: #5CB885 !important;
  border: 2rpx solid #4A9A6E;
}

.seat-vip {
  border: 2rpx solid #FFD700;
}

.seat-quiet {
  border: 2rpx solid #90CAF9;
}

.seat-number {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.corridor {
  width: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.corridor-text {
  font-size: 20rpx;
  color: #999999;
  writing-mode: vertical-rl;
}

.legend {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 32rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #EEEEEE;
}

.legend-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.legend-color {
  width: 32rpx;
  height: 32rpx;
  border-radius: 6rpx;
}

.legend-color.available {
  background: #C8E6C9;
}

.legend-color.occupied {
  background: #E0E0E0;
}

.legend-color.reserved {
  background: #FFF9C4;
}

.legend-color.selected {
  background: #5CB885;
}

.legend-text {
  font-size: 24rpx;
  color: #666666;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  background: #FFFFFF;
  border-radius: 16rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

.selected-info {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
  width: 160rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

.confirm-btn {
  position: fixed;
  bottom: 32rpx;
  left: 32rpx;
  right: 32rpx;
  background: #5CB885;
  border-radius: 48rpx;
  padding: 28rpx 0;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(92, 184, 133, 0.3);
}

.confirm-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
}
