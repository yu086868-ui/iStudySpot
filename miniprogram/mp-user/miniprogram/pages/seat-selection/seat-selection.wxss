page {
  height: 100vh;
  background: #F5F5F7;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  padding: 32rpx;
  padding-bottom: 120rpx;
}

.header {
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1D1D1F;
  letter-spacing: -0.5rpx;
}

.stats-bar {
  margin-top: 16rpx;
}

.stats-text {
  font-size: 26rpx;
  color: #86868B;
}

.datetime-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.picker-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.picker-row:last-child {
  border-bottom: none;
}

.picker-label {
  font-size: 28rpx;
  color: #6E6E73;
  width: 160rpx;
}

.picker-value {
  font-size: 28rpx;
  color: #6EA88A;
  padding: 8rpx 24rpx;
  background: #EAF1ED;
  border-radius: 12rpx;
  font-weight: 500;
}

.picker-separator {
  font-size: 28rpx;
  color: #6E6E73;
  margin: 0 8rpx;
}

.time-display {
  background: #FFFFFF;
  border: 1rpx solid rgba(110, 168, 138, 0.25);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.time-text {
  font-size: 28rpx;
  color: #1D1D1F;
  text-align: center;
  display: block;
  font-weight: 500;
}

.seat-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.seat-map {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 32rpx;
  padding: 24rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.seat-group {
  display: flex;
  flex-direction: column;
}

.group-header {
  display: flex;
  flex-direction: row;
  margin-bottom: 12rpx;
  padding-left: 48rpx;
}

.col-label {
  width: 64rpx;
  text-align: center;
  font-size: 24rpx;
  color: #86868B;
}

.seat-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 8rpx;
}

.row-label {
  width: 40rpx;
  font-size: 24rpx;
  color: #86868B;
  text-align: center;
  margin-right: 8rpx;
}

.seat {
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 4rpx;
}

.seat-available {
  background: #EAF1ED;
}

.seat-occupied {
  background: #E8E8ED;
}

.seat-reserved {
  background: #FFF8EE;
}

.seat-maintenance {
  background: #FEF0F0;
}

.seat-selected {
  background: #6EA88A !important;
  border: 2rpx solid #5A8A6E;
}

.seat-vip {
  border: 2rpx solid rgba(180, 155, 90, 0.5);
}

.seat-quiet {
  border: 2rpx solid rgba(90, 122, 150, 0.4);
}

.seat-number {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.corridor {
  width: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.corridor-text {
  font-size: 20rpx;
  color: #AEAEB2;
  writing-mode: vertical-rl;
}

.legend {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 32rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.legend-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.legend-color {
  width: 32rpx;
  height: 32rpx;
  border-radius: 6rpx;
}

.legend-color.available {
  background: #EAF1ED;
}

.legend-color.occupied {
  background: #E8E8ED;
}

.legend-color.reserved {
  background: #FFF8EE;
}

.legend-color.selected {
  background: #6EA88A;
}

.legend-text {
  font-size: 24rpx;
  color: #6E6E73;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.loading-text {
  font-size: 28rpx;
  color: #86868B;
}

.selected-info {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.info-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #86868B;
  width: 160rpx;
}

.info-value {
  font-size: 28rpx;
  color: #1D1D1F;
  flex: 1;
}

.confirm-btn {
  position: fixed;
  bottom: 32rpx;
  left: 32rpx;
  right: 32rpx;
  background: #6EA88A;
  border-radius: 48rpx;
  padding: 28rpx 0;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(110, 168, 138, 0.2);
}

.confirm-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}
