page {
  height: 100vh;
  background: #F5F5F5;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 32rpx 16rpx;
}

.header-left {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #000000;
}

.info-btn {
  margin-left: 16rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #E8F8EE;
  display: flex;
  align-items: center;
  justify-content: center;
}

.info-icon {
  font-size: 30rpx;
  color: #5CB885;
  font-weight: bold;
}

.sort-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
}

.sort-text {
  font-size: 26rpx;
  color: #333333;
  margin-right: 8rpx;
}

.sort-arrow {
  font-size: 20rpx;
  color: #999999;
}

.card-count {
  padding: 0 32rpx 24rpx;
}

.count-text {
  font-size: 26rpx;
  color: #999999;
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #CCCCCC;
}

.card-scroll {
  flex: 1;
  height: 0;
}

.card-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding: 0 20rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  gap: 16rpx;
}

.card-item {
  width: calc(50% - 8rpx);
}

.card-border {
  background: #FFFFFF;
  border-radius: 16rpx;
  border-left: 6rpx solid #CCCCCC;
  overflow: hidden;
  position: relative;
}

.card-rarity-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
  z-index: 1;
}

.badge-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.card-image {
  width: 100%;
  height: 240rpx;
}

.card-md-area {
  padding: 12rpx;
  overflow: hidden;
  max-height: 280rpx;
}

.card-md-area .markdown-card {
  margin: 0;
  padding: 0;
  background: transparent;
  box-shadow: none;
}

.card-md-area .markdown-card .card-header {
  display: none;
}

.card-md-area ._h1 {
  font-size: 28rpx !important;
  margin-top: 0 !important;
  margin-bottom: 8rpx !important;
  padding-bottom: 0 !important;
  border-bottom: none !important;
  line-height: 1.3 !important;
}

.card-md-area ._h2 {
  font-size: 26rpx !important;
  margin-top: 0 !important;
  margin-bottom: 6rpx !important;
  line-height: 1.3 !important;
}

.card-md-area ._h3 {
  font-size: 24rpx !important;
  margin-top: 0 !important;
  margin-bottom: 4rpx !important;
  line-height: 1.3 !important;
}

.card-md-area ._h4,
.card-md-area ._h5,
.card-md-area ._h6 {
  font-size: 22rpx !important;
  margin-top: 0 !important;
  margin-bottom: 4rpx !important;
  line-height: 1.3 !important;
}

.card-md-area ._p {
  margin: 4rpx 0;
  line-height: 1.5;
  font-size: 22rpx;
}

.card-md-area ._blockquote {
  margin: 8rpx 0;
  padding: 8rpx 12rpx;
  border-left-width: 4rpx;
  font-size: 20rpx;
  line-height: 1.4;
}

.card-md-area ._ul,
.card-md-area ._ol {
  margin: 6rpx 0;
  padding-left: 28rpx;
}

.card-md-area ._li {
  line-height: 1.4;
  margin-bottom: 2rpx;
  font-size: 22rpx;
}

.card-md-area ._code {
  font-size: 18rpx;
  padding: 1rpx 4rpx;
}

.card-md-area ._pre {
  margin: 6rpx 0;
  padding: 8rpx 12rpx;
  font-size: 18rpx;
}

.card-md-area ._hr {
  margin: 8rpx 0;
}

.card-md-area ._b,
.card-md-area ._strong {
  font-size: 22rpx;
}

.card-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 12rpx 16rpx;
}

.card-meta {
  font-size: 20rpx;
  color: #BBBBBB;
}

.card-duration {
  font-size: 20rpx;
  color: #BBBBBB;
}

.sort-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.sort-picker {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.picker-title {
  margin-bottom: 32rpx;
}

.picker-title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.picker-option {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 16rpx;
  border-radius: 12rpx;
}

.picker-option.active {
  background: #E8F8EE;
}

.picker-option-text {
  font-size: 30rpx;
  color: #333333;
}

.picker-option.active .picker-option-text {
  color: #5CB885;
  font-weight: bold;
}

.picker-check {
  font-size: 32rpx;
  color: #5CB885;
  font-weight: bold;
}

.doc-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.3s ease;
}

.doc-popup-mask.doc-mask-show {
  background: rgba(0, 0, 0, 0.6);
}

.doc-popup-container {
  width: 88%;
  height: 80vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  opacity: 0;
  transform: scale(0.6);
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.doc-popup-container.doc-popup-show {
  opacity: 1;
  transform: scale(1);
}

.doc-popup-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
  flex-shrink: 0;
}

.doc-popup-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.doc-popup-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.doc-close-text {
  font-size: 28rpx;
  color: #999999;
  line-height: 1;
}

.doc-popup-body {
  height: calc(80vh - 100rpx);
  padding: 32rpx;
  box-sizing: border-box;
}

.doc-content {
  padding-bottom: 32rpx;
}
