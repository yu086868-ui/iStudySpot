page {
  height: 100vh;
  background: #F5F5F5;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-bottom: 180rpx;
}

.header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 32rpx 16rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #000000;
}

.sort-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
}

.sort-text {
  font-size: 26rpx;
  color: #333333;
  margin-right: 8rpx;
}

.sort-arrow {
  font-size: 20rpx;
  color: #999999;
}

.card-count {
  padding: 0 32rpx 24rpx;
}

.count-text {
  font-size: 26rpx;
  color: #999999;
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #CCCCCC;
}

.card-scroll {
  flex: 1;
  height: 0;
}

.card-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding: 0 20rpx;
  gap: 16rpx;
}

.card-item {
  width: calc(50% - 8rpx);
}

.card-border {
  background: #FFFFFF;
  border-radius: 16rpx;
  border-left: 6rpx solid #CCCCCC;
  overflow: hidden;
  position: relative;
}

.card-rarity-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
  z-index: 1;
}

.badge-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.card-image {
  width: 100%;
  height: 240rpx;
}

.card-md-area {
  padding: 12rpx;
  overflow: hidden;
  max-height: 280rpx;
}

.card-md-area .markdown-card {
  margin: 0;
  padding: 0;
  background: transparent;
  box-shadow: none;
}

.card-md-area .markdown-card .card-header {
  display: none;
}

.card-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 12rpx 16rpx;
}

.card-meta {
  font-size: 20rpx;
  color: #BBBBBB;
}

.card-duration {
  font-size: 20rpx;
  color: #BBBBBB;
}

.sort-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.sort-picker {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.picker-title {
  margin-bottom: 32rpx;
}

.picker-title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.picker-option {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 16rpx;
  border-radius: 12rpx;
}

.picker-option.active {
  background: #E8F8EE;
}

.picker-option-text {
  font-size: 30rpx;
  color: #333333;
}

.picker-option.active .picker-option-text {
  color: #5CB885;
  font-weight: bold;
}

.picker-check {
  font-size: 32rpx;
  color: #5CB885;
  font-weight: bold;
}
