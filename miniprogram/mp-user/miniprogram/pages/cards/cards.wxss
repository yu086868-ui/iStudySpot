page {
  height: 100vh;
  background: #F5F5F7;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 40rpx 32rpx 8rpx;
}

.header-left {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1D1D1F;
  letter-spacing: -0.5rpx;
}

.info-btn {
  margin-left: 16rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #EAF1ED;
  display: flex;
  align-items: center;
  justify-content: center;
}

.info-icon {
  font-size: 30rpx;
  color: #6EA88A;
  font-weight: 600;
}

.filter-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 32rpx 24rpx;
}

.card-count {
  padding: 0;
}

.count-text {
  font-size: 26rpx;
  color: #86868B;
}

.sort-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 8rpx 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.04);
}

.sort-text {
  font-size: 24rpx;
  color: #6E6E73;
  margin-right: 6rpx;
}

.sort-arrow {
  font-size: 18rpx;
  color: #AEAEB2;
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-text {
  font-size: 32rpx;
  color: #86868B;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #AEAEB2;
}

.card-scroll {
  flex: 1;
  height: 0;
}

.card-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding: 0 20rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  gap: 16rpx;
}

.card-item {
  width: calc(50% - 8rpx);
}

.card-border {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.card-border:active {
  transform: scale(0.98);
}

.card-rarity-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  backdrop-filter: blur(4rpx);
}

.badge-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.badge-N {
  background: rgba(176, 176, 176, 0.85);
}

.badge-R {
  background: rgba(76, 175, 80, 0.85);
}

.badge-SR {
  background: rgba(66, 165, 245, 0.85);
}

.badge-SSR {
  background: rgba(171, 71, 188, 0.85);
}

.badge-UR {
  background: linear-gradient(135deg, #c9a84c, #f0d78c);
}

.badge-UR .badge-text {
  color: #3a2a00;
}

.badge-LR {
  background: linear-gradient(135deg, #e53935, #ff6f61);
  animation: lr-pulse 2s ease-in-out infinite;
}

@keyframes lr-pulse {
  0%, 100% { box-shadow: 0 0 8rpx rgba(229, 57, 53, 0.4); }
  50% { box-shadow: 0 0 20rpx rgba(229, 57, 53, 0.7); }
}

.card-image {
  width: 100%;
  height: 240rpx;
}

.card-md-area {
  padding: 12rpx;
  overflow: hidden;
  max-height: 280rpx;
}

.card-md-area .markdown-card {
  margin: 0;
  padding: 0;
  background: transparent;
  box-shadow: none;
}

.card-md-area .markdown-card .card-header {
  display: none;
}

.card-md-area ._h1 {
  font-size: 28rpx !important;
  margin-top: 0 !important;
  margin-bottom: 8rpx !important;
  padding-bottom: 0 !important;
  border-bottom: none !important;
  line-height: 1.3 !important;
}

.card-md-area ._h2 {
  font-size: 26rpx !important;
  margin-top: 0 !important;
  margin-bottom: 6rpx !important;
  line-height: 1.3 !important;
}

.card-md-area ._h3 {
  font-size: 24rpx !important;
  margin-top: 0 !important;
  margin-bottom: 4rpx !important;
  line-height: 1.3 !important;
}

.card-md-area ._h4,
.card-md-area ._h5,
.card-md-area ._h6 {
  font-size: 22rpx !important;
  margin-top: 0 !important;
  margin-bottom: 4rpx !important;
  line-height: 1.3 !important;
}

.card-md-area ._p {
  margin: 4rpx 0;
  line-height: 1.5;
  font-size: 22rpx;
}

.card-md-area ._blockquote {
  margin: 8rpx 0;
  padding: 8rpx 12rpx;
  border-left-width: 4rpx;
  font-size: 20rpx;
  line-height: 1.4;
}

.card-md-area ._ul,
.card-md-area ._ol {
  margin: 6rpx 0;
  padding-left: 28rpx;
}

.card-md-area ._li {
  line-height: 1.4;
  margin-bottom: 2rpx;
  font-size: 22rpx;
}

.card-md-area ._code {
  font-size: 18rpx;
  padding: 1rpx 4rpx;
}

.card-md-area ._pre {
  margin: 6rpx 0;
  padding: 8rpx 12rpx;
  font-size: 18rpx;
}

.card-md-area ._hr {
  margin: 8rpx 0;
}

.card-md-area ._b,
.card-md-area ._strong {
  font-size: 22rpx;
}

.card-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 12rpx 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.card-meta {
  font-size: 20rpx;
  color: #999999;
}

.card-duration {
  font-size: 20rpx;
  color: #999999;
}

.card-border-N {
  border: 4rpx solid #b0b0b0;
  box-shadow: 0 4rpx 16rpx rgba(176, 176, 176, 0.15);
}

.card-border-R {
  border: 4rpx solid #4caf50;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.2);
}

.card-border-SR {
  border: 4rpx solid #42a5f5;
  box-shadow: 0 4rpx 20rpx rgba(66, 165, 245, 0.25);
}

.card-border-SSR {
  border: 4rpx solid #ab47bc;
  box-shadow: 0 4rpx 24rpx rgba(171, 71, 188, 0.3);
  animation: ssr-glow 3s ease-in-out infinite;
}

@keyframes ssr-glow {
  0%, 100% { box-shadow: 0 4rpx 24rpx rgba(171, 71, 188, 0.3); }
  50% { box-shadow: 0 4rpx 32rpx rgba(171, 71, 188, 0.45); }
}

.card-border-UR {
  border: 4rpx solid #c9a84c;
  box-shadow: 0 8rpx 32rpx rgba(201, 168, 76, 0.35);
  background: linear-gradient(160deg, #1a1710, #2a2418, #1a1710);
}

.card-border-UR .card-md-area {
  background: transparent;
}

.card-border-UR .card-footer {
  border-top-color: rgba(201, 168, 76, 0.2);
}

.card-border-UR .card-meta {
  color: #8a7a5a;
}

.card-border-UR .card-duration {
  color: #8a7a5a;
}

.card-border-UR ._h1,
.card-border-UR ._h2,
.card-border-UR ._h3,
.card-border-UR ._h4,
.card-border-UR ._h5,
.card-border-UR ._h6 {
  color: #e8d48b !important;
}

.card-border-UR ._p {
  color: #c8c0a8 !important;
}

.card-border-UR ._blockquote {
  border-left-color: #c9a84c !important;
  color: #c9a84c !important;
}

.card-border-UR ._li {
  color: #c8c0a8 !important;
}

.card-border-LR {
  border: 4rpx solid #e53935;
  box-shadow: 0 8rpx 36rpx rgba(229, 57, 53, 0.4);
  background: linear-gradient(160deg, #1a0a0a, #2a1010, #1a0808);
  animation: lr-card-breathe 3s ease-in-out infinite;
}

@keyframes lr-card-breathe {
  0%, 100% { box-shadow: 0 8rpx 36rpx rgba(229, 57, 53, 0.4); }
  50% { box-shadow: 0 8rpx 48rpx rgba(229, 57, 53, 0.6); }
}

.card-border-LR .card-md-area {
  background: transparent;
}

.card-border-LR .card-footer {
  border-top-color: rgba(229, 57, 53, 0.2);
}

.card-border-LR .card-meta {
  color: #8a5a5a;
}

.card-border-LR .card-duration {
  color: #8a5a5a;
}

.card-border-LR ._h1,
.card-border-LR ._h2,
.card-border-LR ._h3,
.card-border-LR ._h4,
.card-border-LR ._h5,
.card-border-LR ._h6 {
  color: #f5c6c4 !important;
}

.card-border-LR ._p {
  color: #c8a8a6 !important;
}

.card-border-LR ._blockquote {
  border-left-color: #ef5350 !important;
  color: #ef5350 !important;
}

.card-border-LR ._li {
  color: #c8a8a6 !important;
}

.sort-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.sort-picker {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.picker-title {
  margin-bottom: 32rpx;
}

.picker-title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.picker-option {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 16rpx;
  border-radius: 12rpx;
}

.picker-option.active {
  background: #EAF1ED;
}

.picker-option-text {
  font-size: 30rpx;
  color: #1D1D1F;
}

.picker-option.active .picker-option-text {
  color: #6EA88A;
  font-weight: 600;
}

.picker-check {
  font-size: 32rpx;
  color: #6EA88A;
  font-weight: 600;
}

.doc-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.3s ease;
}

.doc-popup-mask.doc-mask-show {
  background: rgba(0, 0, 0, 0.4);
}

.doc-popup-container {
  width: 88%;
  height: 80vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  opacity: 0;
  transform: scale(0.95);
  transition: all 0.25s ease;
}

.doc-popup-container.doc-popup-show {
  opacity: 1;
  transform: scale(1);
}

.doc-popup-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
  flex-shrink: 0;
}

.doc-popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1D1D1F;
}

.doc-popup-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F5F5F7;
  display: flex;
  align-items: center;
  justify-content: center;
}

.doc-close-text {
  font-size: 28rpx;
  color: #86868B;
  line-height: 1;
}

.doc-popup-body {
  height: calc(80vh - 100rpx);
  padding: 32rpx;
  box-sizing: border-box;
}

.doc-content {
  padding-bottom: 32rpx;
}
