<view class="container">
  <view class="header">
    <text class="title">卡片收藏</text>
    <view class="sort-btn" bindtap="onSortTap">
      <text class="sort-text">{{sortOptions[sortMode === 'id' ? 0 : sortMode === 'rarity' ? 1 : 2].label}}</text>
      <text class="sort-arrow">▼</text>
    </view>
  </view>

  <view class="card-count">
    <text class="count-text">共 {{sortedCards.length}} 张</text>
  </view>

  <block wx:if="{{loading && sortedCards.length === 0}}">
    <view class="empty-state">
      <text class="empty-text">加载中...</text>
    </view>
  </block>

  <block wx:elif="{{sortedCards.length === 0}}">
    <view class="empty-state">
      <text class="empty-text">暂无卡片</text>
      <text class="empty-hint">完成学习后即可获得AI卡片</text>
    </view>
  </block>

  <block wx:else>
    <scroll-view
      class="card-scroll"
      scroll-y
      refresher-enabled
      refresher-triggered="{{loading}}"
      bindrefresherrefresh="onRefresh"
    >
      <view class="card-list">
        <view
          class="card-item"
          wx:for="{{sortedCards}}"
          wx:key="uuid"
          data-uuid="{{item.uuid}}"
          bindtap="onCardTap"
        >
          <view class="card-border" style="border-color: {{rarityBorderColor[item.rarity]}}">
            <view class="card-rarity-badge" style="background: {{rarityBorderColor[item.rarity]}}">
              <text class="badge-text">{{item.rarity}}</text>
            </view>
            <image
              class="card-image"
              src="{{item.imageURL}}"
              mode="aspectFill"
            />
            <view class="card-content">
              <text class="card-title">{{item.markdown}}</text>
            </view>
            <view class="card-footer">
              <text class="card-meta">{{item.createTime}}</text>
              <text class="card-duration">{{item.studyDuration}}min</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </block>
</view>

<view class="sort-picker-mask" wx:if="{{showSortPicker}}" bindtap="onSortPickerClose">
  <view class="sort-picker" catchtap="">
    <view class="picker-title">
      <text class="picker-title-text">排序方式</text>
    </view>
    <view
      class="picker-option {{sortMode === item.key ? 'active' : ''}}"
      wx:for="{{sortOptions}}"
      wx:key="key"
      data-mode="{{item.key}}"
      bindtap="onSortSelect"
    >
      <text class="picker-option-text">{{item.label}}</text>
      <text class="picker-check" wx:if="{{sortMode === item.key}}">✓</text>
    </view>
  </view>
</view>

<tab-bar currentTab="cards"></tab-bar>
