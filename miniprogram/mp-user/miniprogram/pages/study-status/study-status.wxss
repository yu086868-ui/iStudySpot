page {
  height: 100vh;
  background: #F5F5F7;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.image-wrapper {
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  border: 4rpx solid #EAF1ED;
  overflow: hidden;
  margin-bottom: 48rpx;
  box-shadow: 0 4rpx 24rpx rgba(110, 168, 138, 0.12);
}

.tree-image {
  width: 100%;
  height: 100%;
  background: #EAF1ED;
}

.status-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.status-title {
  font-size: 30rpx;
  color: #6EA88A;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.status-time {
  font-size: 52rpx;
  font-weight: 700;
  color: #1D1D1F;
  letter-spacing: -1rpx;
  margin-bottom: 20rpx;
}

.status-motto {
  font-size: 26rpx;
  color: #86868B;
}

.exit-btn {
  background: #E8E8ED;
  border-radius: 48rpx;
  padding: 24rpx 80rpx;
  margin-bottom: 24rpx;
}

.exit-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #6E6E73;
}

.footer-hint {
  font-size: 24rpx;
  color: #AEAEB2;
}
