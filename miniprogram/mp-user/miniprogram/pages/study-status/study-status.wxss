page {
  height: 100vh;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.image-wrapper {
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  border: 8rpx solid #E8F8EE;
  overflow: hidden;
  margin-bottom: 48rpx;
}

.tree-image {
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #E8F5E9 0%, #C8E6C9 50%, #A5D6A7 100%);
}

.status-card {
  background: #E8F8EE;
  border-radius: 24rpx;
  padding: 40rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.status-title {
  font-size: 30rpx;
  color: #5CB885;
  margin-bottom: 12rpx;
}

.status-time {
  font-size: 52rpx;
  font-weight: bold;
  color: #5CB885;
  margin-bottom: 20rpx;
}

.status-motto {
  font-size: 26rpx;
  color: #5CB885;
}

.exit-btn {
  background: #fcdcdcff;
  border-radius: 48rpx;
  padding: 24rpx 80rpx;
  margin-bottom: 24rpx;
}

.exit-btn-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.footer-hint {
  font-size: 24rpx;
  color: #CCCCCC;
}
