page {
  height: 100vh;
  background-color: transparent;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  padding: 40rpx 32rpx;
  padding-bottom: 180rpx;
}

.profile-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 56rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.avatar-wrapper {
  margin-bottom: 28rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #EAF1ED;
}

.username {
  font-size: 44rpx;
  font-weight: 600;
  color: #1D1D1F;
  letter-spacing: -0.5rpx;
  margin-bottom: 36rpx;
}

.stats {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-text {
  font-size: 28rpx;
  color: #6E6E73;
  line-height: 1.7;
}

.motto-section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.motto-row {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.motto-label {
  font-size: 24rpx;
  color: #86868B;
  margin-bottom: 8rpx;
}

.motto-value {
  font-size: 30rpx;
  color: #1D1D1F;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.motto-edit-btn {
  padding: 8rpx 20rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.motto-edit-text {
  font-size: 24rpx;
  color: #6EA88A;
  font-weight: 500;
}

.tree-section {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  min-height: 0;
  overflow: hidden;
}

.tree-image {
  width: 400rpx;
  height: 400rpx;
  opacity: 0.4;
}
