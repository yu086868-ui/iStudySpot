page {
  height: 100vh;
  background: #F5F5F5;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  padding: 40rpx 32rpx;
  padding-bottom: 180rpx;
}

.profile-card {
  background: #8FE3B8;
  border-radius: 32rpx;
  padding: 60rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar-wrapper {
  margin-bottom: 32rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.username {
  font-size: 48rpx;
  font-weight: bold;
  color: #000000;
  margin-bottom: 40rpx;
}

.stats {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-text {
  font-size: 28rpx;
  color: #000000;
  line-height: 1.6;
}

.motto-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.motto-row {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.motto-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.motto-value {
  font-size: 30rpx;
  color: #333333;
  font-weight: bold;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.motto-edit-btn {
  padding: 12rpx 28rpx;
  background: #5CB885;
  border-radius: 24rpx;
  margin-left: 24rpx;
  flex-shrink: 0;
}

.motto-edit-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: bold;
}
