page {
  height: 100vh;
  background: #F5F5F5;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  padding: 40rpx 32rpx;
  padding-bottom: 180rpx;
}

.profile-card {
  background: #8FE3B8;
  border-radius: 32rpx;
  padding: 60rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar-wrapper {
  margin-bottom: 32rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.username {
  font-size: 48rpx;
  font-weight: bold;
  color: #000000;
  margin-bottom: 40rpx;
}

.stats {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-text {
  font-size: 28rpx;
  color: #000000;
  line-height: 1.6;
}

.menu-list {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  padding: 36rpx 32rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-text {
  font-size: 32rpx;
  color: #333333;
}
