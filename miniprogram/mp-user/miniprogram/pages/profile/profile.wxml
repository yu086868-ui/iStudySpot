<view class="container">
  <view class="profile-card">
    <view class="avatar-wrapper" bindtap="handleChooseAvatar">
      <image class="avatar" src="{{userInfo.avatarUrl || '/assets/avatar-placeholder.png'}}" mode="aspectFill" binderror="onAvatarError"></image>
    </view>
    <text class="username" bindtap="handleEditNickname">{{userInfo.nickname || '未设置昵称'}}</text>
    <view class="stats">
      <text class="stat-text">累计学习时长：{{studyHours}}H</text>
      <text class="stat-text">预约次数：{{reservationCount}}</text>
      <text class="stat-text">信用分：{{creditScore}}</text>
    </view>
  </view>

  <view class="motto-section">
    <view class="motto-row">
      <text class="motto-label">座右铭</text>
      <text class="motto-value">{{motto}}</text>
    </view>
    <view class="motto-edit-btn" bindtap="handleEditMotto">
      <text class="motto-edit-text">修改</text>
    </view>
  </view>

  <view class="tree-section">
    <image class="tree-image" src="/assets/profile/tree.png" mode="aspectFit"></image>
  </view>
</view>

<tab-bar currentTab="profile"></tab-bar>
