<view class="container">
  <text class="page-title">规则与公告：</text>

  <view class="rule-card" wx:if="{{rules.length > 0}}">
    <view class="rule-header">
      <text class="rule-icon">📌</text>
      <text class="rule-title">自习室公约：</text>
    </view>
    <view class="rule-content">
      <block wx:for="{{rules}}" wx:key="id">
        <text class="rule-text">{{item.content}}</text>
      </block>
    </view>
  </view>

  <view class="notice-card" wx:for="{{announcements}}" wx:key="id">
    <view class="notice-title">{{item.title}}</view>
    <text class="notice-content">{{item.content}}</text>
  </view>

  <view class="empty-state" wx:if="{{announcements.length === 0 && rules.length === 0}}">
    <text class="empty-text">暂无规则和公告</text>
  </view>
</view>

<tab-bar currentTab="rules"></tab-bar>