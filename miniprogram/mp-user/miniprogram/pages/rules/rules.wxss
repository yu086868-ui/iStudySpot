page {
  height: 100vh;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
}

.scroll-content {
  flex: 1;
  height: 0;
}

.container {
  padding: 24rpx 32rpx;
  padding-bottom: 180rpx;
}

.rule-card {
  background: #E8F8EE;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.rule-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 24rpx;
}

.rule-icon-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: #5CB885;
  margin-right: 12rpx;
}

.rule-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #000000;
}

.rule-content {
  display: flex;
  flex-direction: column;
}

.rule-item {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.rule-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.rule-item-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.rule-text {
  font-size: 28rpx;
  color: #555555;
  line-height: 1.8;
  margin-bottom: 4rpx;
}

.notice-section {
  margin-bottom: 32rpx;
}

.notice-section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 24rpx;
}

.notice-icon-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: #E8A84C;
  margin-right: 12rpx;
}

.notice-section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #000000;
}

.notice-card {
  background: #FAFFF8;
  border: 2rpx solid #E0E0E0;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
}

.notice-card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #000000;
  flex: 1;
  margin-right: 16rpx;
}

.notice-priority {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.priority-high {
  background: #FEE2E2;
  color: #DC2626;
}

.priority-medium {
  background: #FEF3C7;
  color: #D97706;
}

.priority-low {
  background: #E0F2FE;
  color: #0284C7;
}

.notice-content {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.7;
  margin-bottom: 16rpx;
}

.notice-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.notice-author {
  font-size: 24rpx;
  color: #999999;
}

.notice-time {
  font-size: 24rpx;
  color: #999999;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}
