page {
  height: 100vh;
  background: #F5F5F7;
  display: flex;
  flex-direction: column;
  padding-top: 0;
}

.scroll-content {
  flex: 1;
  height: 0;
}

.container {
  padding: 24rpx 32rpx;
  padding-bottom: 180rpx;
}

.rule-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.rule-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 28rpx;
}

.rule-icon-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 5rpx;
  background: #6EA88A;
  margin-right: 14rpx;
}

.rule-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D1D1F;
  letter-spacing: 0.5rpx;
}

.rule-content {
  display: flex;
  flex-direction: column;
}

.rule-item {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.rule-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.rule-item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 12rpx;
}

.rule-text {
  font-size: 28rpx;
  color: #6E6E73;
  line-height: 1.8;
  margin-bottom: 4rpx;
}

.notice-section {
  margin-bottom: 32rpx;
}

.notice-section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 20rpx;
  padding-left: 4rpx;
}

.notice-icon-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 5rpx;
  background: #C78D2E;
  margin-right: 14rpx;
}

.notice-section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1D1D1F;
  letter-spacing: 0.5rpx;
}

.notice-card {
  background: #FFFFFF;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.notice-card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
  flex: 1;
  margin-right: 16rpx;
}

.notice-priority {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.priority-high {
  background: #FEF0F0;
  color: #C0392B;
}

.priority-medium {
  background: #FFF8EE;
  color: #C78D2E;
}

.priority-low {
  background: #F0F4F8;
  color: #5A7A96;
}

.notice-content {
  font-size: 28rpx;
  color: #1D1D1F;
  line-height: 1.7;
  margin-bottom: 16rpx;
}

.notice-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.notice-author {
  font-size: 24rpx;
  color: #86868B;
}

.notice-time {
  font-size: 24rpx;
  color: #86868B;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #86868B;
}
