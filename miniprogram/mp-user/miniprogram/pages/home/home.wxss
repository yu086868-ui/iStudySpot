page {
  height: 100vh;
  background: #F6F7F8;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  padding: 48rpx 32rpx;
  padding-bottom: 180rpx;
}

.header {
  margin-bottom: 48rpx;
  padding-left: 4rpx;
}

.title {
  font-size: 52rpx;
  font-weight: 700;
  color: #1D1D1F;
  letter-spacing: -0.5rpx;
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #86868B;
  font-weight: 400;
  display: block;
  line-height: 1.5;
}

/* ===== 卡片布局区域 ===== */
.action-area {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

/* ===== 主功能卡片：重新预约 ===== */
.card-primary {
  flex: 1;
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #60B27A, #7BCF95);
  border-radius: 24rpx;
  padding: 36rpx 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 340rpx;
  box-shadow: 0 8rpx 32rpx rgba(96, 178, 122, 0.25);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.card-primary-active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(96, 178, 122, 0.2);
}

.card-primary-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 24rpx;
}

.card-primary-content {
  position: relative;
  z-index: 2;
}

.card-primary-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
  margin-bottom: 8rpx;
}

.card-primary-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  display: block;
}

.card-primary-arrow {
  position: absolute;
  right: 24rpx;
  bottom: 28rpx;
  width: 52rpx;
  height: 52rpx;
  z-index: 2;
}

.card-primary-texture {
  position: absolute;
  right: -20rpx;
  bottom: -20rpx;
  width: 260rpx;
  height: 260rpx;
  opacity: 0.1;
  z-index: 1;
  border-radius: 50%;
}

/* ===== 次功能卡片组 ===== */
.card-secondary-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card-secondary {
  flex: 1;
  position: relative;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.card-secondary-active {
  transform: scale(0.97);
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.03);
}

.card-secondary-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.card-secondary-content {
  flex: 1;
  min-width: 0;
}

.card-secondary-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
  display: block;
  margin-bottom: 4rpx;
}

.card-secondary-subtitle {
  font-size: 24rpx;
  color: rgba(29, 29, 31, 0.5);
  display: block;
}

.card-secondary-arrow {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ===== 信息卡片 ===== */
.info-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  padding-bottom: 36rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.status-badge {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.status-none {
  background: #F2F2F7;
}

.status-none .status-text {
  color: #8E8E93;
}

.status-reserved {
  background: #FFF8EE;
}

.status-reserved .status-text {
  color: #C78D2E;
}

.status-studying {
  background: #EAF1ED;
}

.status-studying .status-text {
  color: #5A8A6E;
}

.status-checked_out {
  background: #F2F2F7;
}

.status-checked_out .status-text {
  color: #8E8E93;
}

.info-text {
  font-size: 28rpx;
  color: #1D1D1F;
  line-height: 1.7;
}