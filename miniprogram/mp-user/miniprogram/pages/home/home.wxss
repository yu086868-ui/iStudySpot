page {
  height: 100vh;
  background: #F5F5F7;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  padding: 48rpx 32rpx;
  padding-bottom: 180rpx;
}

.header {
  margin-bottom: 48rpx;
  padding-left: 4rpx;
}

.title {
  font-size: 52rpx;
  font-weight: 700;
  color: #1D1D1F;
  letter-spacing: -0.5rpx;
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #86868B;
  font-weight: 400;
  display: block;
  line-height: 1.5;
}

.action-area {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.btn-large {
  flex: 1;
  background: #6EA88A;
  border-radius: 20rpx;
  height: 260rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(110, 168, 138, 0.2);
  transition: background 0.15s ease;
}

.btn-large-active {
  background: #639B7E;
}

.btn-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-small {
  flex: 1;
  background: #FFFFFF;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: background 0.15s ease;
}

.btn-small-active {
  background: #F5F5F7;
}

.btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.btn-small .btn-text {
  color: #6EA88A;
}

.info-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  padding-bottom: 36rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.status-badge {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.status-none {
  background: #F2F2F7;
}

.status-none .status-text {
  color: #8E8E93;
}

.status-reserved {
  background: #FFF8EE;
}

.status-reserved .status-text {
  color: #C78D2E;
}

.status-studying {
  background: #EAF1ED;
}

.status-studying .status-text {
  color: #5A8A6E;
}

.status-checked_out {
  background: #F2F2F7;
}

.status-checked_out .status-text {
  color: #8E8E93;
}

.info-text {
  font-size: 28rpx;
  color: #1D1D1F;
  line-height: 1.7;
}
