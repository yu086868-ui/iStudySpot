page {
  height: 100vh;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  padding: 40rpx 32rpx;
  padding-bottom: 180rpx;
}

.header {
  margin-bottom: 80rpx;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #000000;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666666;
}

.action-area {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.btn-large {
  flex: 1;
  background: #5CB885;
  border-radius: 24rpx;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.btn-small {
  flex: 1;
  background: #5CB885;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.info-card {
  background: #E8F8EE;
  border-radius: 16rpx;
  padding: 32rpx;
}

.status-badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.status-text {
  font-size: 24rpx;
  font-weight: bold;
}

.status-none {
  background: #E0E0E0;
}

.status-none .status-text {
  color: #666666;
}

.status-reserved {
  background: #FFF9C4;
}

.status-reserved .status-text {
  color: #F57C00;
}

.status-studying {
  background: #C8E6C9;
}

.status-studying .status-text {
  color: #2E7D32;
}

.status-checked_out {
  background: #E0E0E0;
}

.status-checked_out .status-text {
  color: #666666;
}

.info-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

.info-dots {
  font-size: 28rpx;
  color: #333333;
  letter-spacing: 8rpx;
  margin-top: 8rpx;
}
