page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  padding: 0 32rpx;
  padding-bottom: 180rpx;
  position: relative;
  background-color: #F6F7F8;
  background-image: url('/assets/home/bg-texture.svg');
  background-size: 100% auto;
  background-repeat: no-repeat;
  background-position: top center;
}

/* ===== Hero区域 ===== */
.hero {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  padding-top: 40rpx;
  margin-bottom: 40rpx;
  min-height: 200rpx;
  position: relative;
}

.hero-text {
  flex: 1;
  padding-top: 16rpx;
}

.hero-title {
  font-size: 80rpx;
  font-weight: 800;
  color: #1D1D1F;
  letter-spacing: -1rpx;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.1;
  text-shadow: 0 2rpx 8rpx rgba(29, 29, 31, 0.06);
}

.hero-motto {
  font-size: 30rpx;
  color: #86868B;
  font-weight: 400;
  display: block;
  line-height: 1.6;
  letter-spacing: 0.5rpx;
}

.hero-leaf {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  margin-top: -24rpx;
  margin-right: -16rpx;
  opacity: 0.85;
}

/* ===== 卡片布局区域 ===== */
.action-area {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

/* ===== 主功能卡片：重新预约 ===== */
.card-primary {
  flex: 1;
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #60B27A, #7BCF95);
  border-radius: 24rpx;
  padding: 36rpx 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 340rpx;
  box-shadow: 0 8rpx 32rpx rgba(96, 178, 122, 0.25);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.card-primary-active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(96, 178, 122, 0.2);
}

.card-primary-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 24rpx;
}

.card-primary-content {
  position: relative;
  z-index: 2;
}

.card-primary-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
  margin-bottom: 8rpx;
}

.card-primary-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  display: block;
}

.card-primary-arrow {
  position: absolute;
  right: 24rpx;
  bottom: 28rpx;
  width: 52rpx;
  height: 52rpx;
  z-index: 2;
}

.card-primary-texture {
  position: absolute;
  right: -20rpx;
  bottom: -20rpx;
  width: 260rpx;
  height: 260rpx;
  opacity: 0.1;
  z-index: 1;
  border-radius: 50%;
}

/* ===== 次功能卡片组 ===== */
.card-secondary-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card-secondary {
  flex: 1;
  position: relative;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.card-secondary-active {
  transform: scale(0.97);
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.03);
}

.card-secondary-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.card-secondary-content {
  flex: 1;
  min-width: 0;
}

.card-secondary-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1D1D1F;
  display: block;
  margin-bottom: 4rpx;
}

.card-secondary-subtitle {
  font-size: 24rpx;
  color: rgba(29, 29, 31, 0.5);
  display: block;
}

.card-secondary-arrow {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ===== 预约信息卡片 ===== */
.info-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  position: relative;
}

.info-card-header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.info-card-lamp {
  width: 100rpx;
  height: 100rpx;
  flex-shrink: 0;
  margin-top: -12rpx;
  margin-right: -8rpx;
  opacity: 0.9;
}

.status-badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
}

.status-text {
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.status-none {
  background: #F2F2F7;
}

.status-none .status-text {
  color: #8E8E93;
}

.status-reserved {
  background: #FFF8EE;
}

.status-reserved .status-text {
  color: #C78D2E;
}

.status-studying {
  background: #EAF1ED;
}

.status-studying .status-text {
  color: #5A8A6E;
}

.status-checked_out {
  background: #F2F2F7;
}

.status-checked_out .status-text {
  color: #8E8E93;
}

/* 信息行 */
.info-card-body {
  margin-bottom: 28rpx;
}

.info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 20rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-row-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.info-row-text {
  font-size: 30rpx;
  color: #1D1D1F;
  font-weight: 500;
  line-height: 1.5;
}

.info-empty-text {
  font-size: 30rpx;
  color: #8E8E93;
  font-weight: 400;
  line-height: 1.6;
  padding: 16rpx 0;
}

/* 卡片底部：本周学习时长 */
.info-card-footer {
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  padding-top: 24rpx;
  margin-top: 4rpx;
}

.weekly-stat {
  display: flex;
  flex-direction: row;
  align-items: baseline;
}

.weekly-stat-label {
  font-size: 26rpx;
  color: #86868B;
  font-weight: 400;
  margin-right: 12rpx;
}

.weekly-stat-value {
  font-size: 52rpx;
  color: #60B27A;
  font-weight: 700;
  line-height: 1;
  margin-right: 6rpx;
}

.weekly-stat-unit {
  font-size: 26rpx;
  color: #86868B;
  font-weight: 400;
}