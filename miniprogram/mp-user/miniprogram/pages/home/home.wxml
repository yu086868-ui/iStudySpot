<view class="container">
  <view class="header">
    <text class="title">Hello~</text>
    <text class="subtitle">{{motto}}</text>
  </view>

  <view class="action-area">
    <!-- 主功能卡片：重新预约 -->
    <view class="card-primary" hover-class="card-primary-active" bindtap="handleReserveButton">
      <image class="card-primary-icon" src="/assets/home/calendar.svg" mode="aspectFit" />
      <view class="card-primary-content">
        <text class="card-primary-title">{{reserveButtonText}}</text>
        <text class="card-primary-subtitle">预约自习座位</text>
      </view>
      <image class="card-primary-arrow" src="/assets/home/arrow-white.svg" mode="aspectFit" />
      <image class="card-primary-texture" src="/assets/home/plant-texture.jpg" mode="aspectFit" />
    </view>

    <!-- 次功能卡片组 -->
    <view class="card-secondary-group">
      <!-- 签到 / 学习 -->
      <view class="card-secondary" hover-class="card-secondary-active" bindtap="handleCheckInButton">
        <image class="card-secondary-icon" src="/assets/home/study.svg" mode="aspectFit" />
        <view class="card-secondary-content">
          <text class="card-secondary-title">{{checkInButtonText}}</text>
          <text class="card-secondary-subtitle">记录学习时长</text>
        </view>
        <image class="card-secondary-arrow" src="/assets/home/arrow-green.svg" mode="aspectFit" />
      </view>

      <!-- 扫码签到 -->
      <view class="card-secondary" hover-class="card-secondary-active" bindtap="scanCheckIn">
        <image class="card-secondary-icon" src="/assets/home/qrcode.svg" mode="aspectFit" />
        <view class="card-secondary-content">
          <text class="card-secondary-title">扫码签到</text>
          <text class="card-secondary-subtitle">快速扫码签到</text>
        </view>
        <image class="card-secondary-arrow" src="/assets/home/arrow-green.svg" mode="aspectFit" />
      </view>
    </view>
  </view>

  <view class="info-card">
    <view class="status-badge status-{{userState}}">
      <text class="status-text">{{stateDisplayText}}</text>
    </view>
    
    <block wx:if="{{userState === 'studying' && currentReservation}}">
      <text class="info-text">正在{{currentReservation.roomName}}学习，</text>
      <text class="info-text">座位号：{{currentReservation.seatNumber}}，</text>
      <text class="info-text">已学习 {{currentReservation.displayTime}}，</text>
      <text class="info-text">本周累计学习 {{weeklyStudyHours}} 小时。</text>
    </block>
    
    <block wx:elif="{{userState === 'reserved' && currentReservation}}">
      <text class="info-text">已预约{{currentReservation.roomName}} {{currentReservation.displayTime}}，</text>
      <text class="info-text">座位号：{{currentReservation.seatNumber}}，</text>
      <text class="info-text">请按时前往自习。</text>
      <text class="info-text">本周累计学习 {{weeklyStudyHours}} 小时。</text>
    </block>
    
    <block wx:else>
      <text class="info-text">暂无进行中的预约</text>
      <text class="info-text">本周累计学习 {{weeklyStudyHours}} 小时。</text>
    </block>
  </view>
</view>

<tab-bar currentTab="home"></tab-bar>