/* ===== 底部导航栏容器 ===== */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.04);
}

/* ===== 顶部细微分隔线 ===== */
.tab-bar-border {
  display: none;
}

/* ===== 单个 Tab 项 ===== */
.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 120rpx;
  position: relative;
}

/* ===== 图标包裹层（选中时作为背景指示器）===== */
.tab-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  margin-bottom: 6rpx;
  transition: background 0.2s ease;
}

/* 选中状态：图标包裹层背景 */
.tab-item.active .tab-icon-wrap {
  background: #F4FAF6;
}

/* ===== 图标样式 ===== */
.tab-icon {
  width: 48rpx;
  height: 48rpx;
}

/* ===== 文字样式 ===== */
.tab-text {
  font-size: 22rpx;
  color: #B8B8BD;
  line-height: 1.4;
  letter-spacing: 0.5rpx;
  font-weight: 400;
}

/* 选中状态：文字颜色与字重 */
.tab-item.active .tab-text {
  color: #60B27A;
  font-weight: 600;
}