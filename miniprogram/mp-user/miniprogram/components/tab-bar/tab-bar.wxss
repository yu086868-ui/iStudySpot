/* ===== 底部导航栏容器 ===== */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

/* ===== 顶部细微分隔线 ===== */
.tab-bar-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: rgba(0, 0, 0, 0.05);
  transform: scaleY(0.5);
}

/* ===== 单个 Tab 项 ===== */
.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100rpx;
  position: relative;
}

/* ===== 图标包裹层（选中时作为背景指示器）===== */
.tab-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  margin-bottom: 4rpx;
}

/* 选中状态：图标包裹层背景 */
.tab-item.active .tab-icon-wrap {
  background: #F4FAF6;
}

/* ===== 图标样式 ===== */
.tab-icon {
  width: 44rpx;
  height: 44rpx;
}

/* ===== 文字样式 ===== */
.tab-text {
  font-size: 20rpx;
  color: #B8B8BD;
  line-height: 1.4;
  letter-spacing: 0.2rpx;
}

/* 选中状态：文字颜色与字重 */
.tab-item.active .tab-text {
  color: #60B27A;
  font-weight: 600;
}
