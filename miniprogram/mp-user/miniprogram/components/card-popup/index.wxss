.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.3s ease;
}

.popup-mask.mask-show {
  background: rgba(0, 0, 0, 0.45);
}

.popup-container {
  width: 85%;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0;
  transform: scale(0.95);
  transition: all 0.25s ease;
}

.popup-container.popup-show {
  opacity: 1;
  transform: scale(1);
}

.popup-close {
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.1);
}

.close-text {
  font-size: 32rpx;
  color: #86868B;
  line-height: 1;
}

.popup-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
}

.popup-rarity-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.popup-badge-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.badge-N {
  background: rgba(142, 142, 147, 0.85);
}

.badge-R {
  background: rgba(110, 168, 138, 0.9);
}

.badge-SR {
  background: rgba(90, 122, 150, 0.9);
}

.badge-SSR {
  background: rgba(138, 109, 158, 0.9);
}

.badge-UR {
  background: rgba(180, 155, 90, 0.9);
}

.badge-LR {
  background: rgba(175, 90, 90, 0.9);
}

.popup-image {
  width: 100%;
  height: 400rpx;
}

.popup-md-area {
  padding: 24rpx 28rpx;
  max-height: 400rpx;
  overflow: hidden;
}

.popup-md-area .markdown-card {
  margin: 0;
  padding: 0;
  background: transparent;
  box-shadow: none;
}

.popup-md-area .markdown-card .card-header {
  display: none;
}

.popup-footer {
  padding: 16rpx 28rpx 28rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.popup-meta-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.popup-meta-text {
  font-size: 24rpx;
  color: #86868B;
}

.popup-theme-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
}

.popup-theme-text {
  font-size: 22rpx;
  color: #86868B;
  padding: 6rpx 16rpx;
  background: #F5F5F7;
  border-radius: 12rpx;
}

.popup-action {
  margin-top: 32rpx;
}

.action-btn {
  background: #6EA88A;
  border-radius: 48rpx;
  padding: 20rpx 80rpx;
  box-shadow: 0 4rpx 20rpx rgba(110, 168, 138, 0.2);
}

.action-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.popup-card-N {
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.popup-card-R {
  border: 1rpx solid rgba(110, 168, 138, 0.3);
  box-shadow: 0 4rpx 28rpx rgba(110, 168, 138, 0.15);
}

.popup-card-SR {
  border: 1rpx solid rgba(90, 122, 150, 0.3);
  box-shadow: 0 6rpx 32rpx rgba(90, 122, 150, 0.15);
}

.popup-card-SSR {
  border: 1rpx solid rgba(138, 109, 158, 0.3);
  box-shadow: 0 6rpx 36rpx rgba(138, 109, 158, 0.18);
}

.popup-card-UR {
  border: 1rpx solid rgba(180, 155, 90, 0.35);
  box-shadow: 0 8rpx 40rpx rgba(180, 155, 90, 0.2);
  background: #2A2418;
}

.popup-card-UR .popup-md-area {
  background: transparent;
}

.popup-card-UR .popup-footer {
  border-top-color: rgba(180, 155, 90, 0.2);
}

.popup-card-UR .popup-meta-text {
  color: #8A7A5A;
}

.popup-card-UR .popup-theme-text {
  background: rgba(180, 155, 90, 0.15);
  color: #B49B5A;
}

.popup-card-LR {
  border: 1rpx solid rgba(175, 90, 90, 0.35);
  box-shadow: 0 8rpx 40rpx rgba(175, 90, 90, 0.2);
  background: #2A1010;
}

.popup-card-LR .popup-md-area {
  background: transparent;
}

.popup-card-LR .popup-footer {
  border-top-color: rgba(175, 90, 90, 0.2);
}

.popup-card-LR .popup-meta-text {
  color: #8A5A5A;
}

.popup-card-LR .popup-theme-text {
  background: rgba(175, 90, 90, 0.15);
  color: #AF5A5A;
}

.popup-card-UR ._h1,
.popup-card-UR ._h2,
.popup-card-UR ._h3,
.popup-card-UR ._h4,
.popup-card-UR ._h5,
.popup-card-UR ._h6 {
  color: #D4C48A !important;
}

.popup-card-UR ._p {
  color: #B8B098 !important;
}

.popup-card-UR ._blockquote {
  border-left-color: #B49B5A !important;
  color: #B49B5A !important;
}

.popup-card-UR ._li {
  color: #B8B098 !important;
}

.popup-card-LR ._h1,
.popup-card-LR ._h2,
.popup-card-LR ._h3,
.popup-card-LR ._h4,
.popup-card-LR ._h5,
.popup-card-LR ._h6 {
  color: #D4A8A6 !important;
}

.popup-card-LR ._p {
  color: #B89896 !important;
}

.popup-card-LR ._blockquote {
  border-left-color: #AF5A5A !important;
  color: #AF5A5A !important;
}

.popup-card-LR ._li {
  color: #B89896 !important;
}
