.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.3s ease;
}

.popup-mask.mask-show {
  background: rgba(0, 0, 0, 0.6);
}

.popup-container {
  width: 85%;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0;
  transform: scale(0.6);
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.popup-container.popup-show {
  opacity: 1;
  transform: scale(1);
}

.popup-close {
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.close-text {
  font-size: 32rpx;
  color: #666666;
  line-height: 1;
}

.popup-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx;
  border-left: 8rpx solid #CCCCCC;
  overflow: hidden;
  position: relative;
}

.popup-rarity-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 6rpx 20rpx;
  border-radius: 16rpx;
  z-index: 2;
}

.popup-badge-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.popup-image {
  width: 100%;
  height: 400rpx;
}

.popup-md-scroll {
  max-height: 400rpx;
}

.popup-md-area {
  padding: 24rpx 28rpx;
}

.popup-md-area .markdown-card {
  margin: 0;
  padding: 0;
  background: transparent;
  box-shadow: none;
}

.popup-md-area .markdown-card .card-header {
  display: none;
}

.popup-footer {
  padding: 16rpx 28rpx 28rpx;
  border-top: 1rpx solid #F0F0F0;
}

.popup-meta-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.popup-meta-text {
  font-size: 24rpx;
  color: #999999;
}

.popup-theme-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
}

.popup-theme-text {
  font-size: 22rpx;
  color: #BBBBBB;
  padding: 4rpx 16rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
}

.popup-action {
  margin-top: 32rpx;
}

.action-btn {
  background: #5CB885;
  border-radius: 48rpx;
  padding: 20rpx 80rpx;
}

.action-btn-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #FFFFFF;
}
