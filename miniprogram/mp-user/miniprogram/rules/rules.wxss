page {
  height: 100vh;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
}

.container {
  flex: 1;
  padding: 32rpx;
  padding-bottom: 180rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #000000;
  margin-bottom: 32rpx;
}

.rule-card {
  background: #E8F8EE;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.rule-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 24rpx;
}

.rule-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.rule-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #000000;
}

.rule-content {
  display: flex;
  flex-direction: column;
}

.rule-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.notice-card {
  background: #FAFFF8;
  border: 2rpx solid #E0E0E0;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  background-image:
    linear-gradient(90deg, rgba(200, 200, 200, 0.1) 1px, transparent 1px),
    linear-gradient(rgba(200, 200, 200, 0.1) 1px, transparent 1px);
  background-size: 40rpx 40rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #000000;
  margin-bottom: 16rpx;
}

.notice-content {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.7;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}
