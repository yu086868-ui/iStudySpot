{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2020",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowJs": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "strict": false,
    "types": ["jest", "node"],
    "outDir": "./dist-test",
    "declaration": false,
    "sourceMap": false,
    "skipLibCheck": true,
    "rootDir": "./miniprogram"
  },
  "include": [
    "miniprogram/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-test"
  ]
}
